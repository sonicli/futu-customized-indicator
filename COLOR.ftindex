{CALCULATE MAS USING PARAMETERS P1 AND P2}
MA1:=MA(CLOSE, P1);
MA2:=MA(CLOSE, P2);

{1. FILL BETWEEN THE TWO MAS}
FILLRGN(MA1, MA2, MA1 > MA2, COLOR320000);
FILLRGN(MA1, MA2, MA1 < MA2, COLOR003200);

{2. DRAW MA LINES}
LINE1:MA1, COLORWHITE;
LINE2:MA2, COLORYELLOW;

{3. REDRAW CANDLES (BEHIND TEXT)}
DRAWKLINE(H, O, L, C);

{4. SIGNAL LABELS — AT CROSSOVER}
DRAWTEXT(CROSS(MA1, MA2), LOW * 0.99, '加倉'), COLORRED;
DRAWTEXT(CROSS(MA2, MA1), HIGH * 1.01, '止損'), COLORGREEN;